// MyAttendance - Prisma Schema (MySQL)
// Replaces all Mongoose models: User, Student, Teacher, Course, CourseAllocation, Attendance

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─────────────────────────────────────────────
// USER — Core auth entity (students & teachers login via this)
// ─────────────────────────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  student          Student?
  teacher          Teacher?
  libraryResources LibraryResource[]
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

// ─────────────────────────────────────────────
// DEPARTMENT 
// ─────────────────────────────────────────────
model DepartmentInfo {
  id              Int      @id @default(autoincrement())
  name            String
  code            String
  semesterDetails Json // Stores the array of objects mentioned above
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────────
// STUDENT — Profile linked to a User
// ─────────────────────────────────────────────
model Student {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  rollNumber    String   @unique
  department    String
  semester      Int
  section       String   @default("A")
  batch         String
  contactNumber String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrolledCourses   StudentCourse[] // Many-to-many with Course
  attendanceRecords AttendanceRecord[] // All attendance records for this student
  attendanceStats   StudentAttendanceStat[] // Cached attendance per course
}

// ─────────────────────────────────────────────
// TEACHER — Profile linked to a User
// ─────────────────────────────────────────────
model Teacher {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  employeeId  String   @unique
  designation String
  department  String
  contactNumber String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseAllocations CourseAllocation[]
  schedules         TeacherSchedule[]
}

// ─────────────────────────────────────────────
// TEACHER SCHEDULE — Replaces teacher.schedule[] embedded array
// ─────────────────────────────────────────────
model TeacherSchedule {
  id                 Int     @id @default(autoincrement())
  teacherId          Int
  courseAllocationId Int
  day                String // e.g. "Monday"
  slots              String // e.g. "1,2" (comma-separated slot numbers)
  room               String?
  classType          String  @default("class") // "class" or "lab"

  teacher          Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  courseAllocation CourseAllocation @relation(fields: [courseAllocationId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([courseAllocationId])
}

// ─────────────────────────────────────────────
// CLASS TIMETABLE — Stores period structure per class (dept+sem+sec)
// ─────────────────────────────────────────────
model ClassTimetable {
  id         Int      @id @default(autoincrement())
  department String
  semester   Int
  section    String
  periods    Json     @default("[]") // [{period:1, startTime:"09:00", endTime:"10:00", type:"class"}]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  entries ClassScheduleEntry[]

  @@unique([department, semester, section])
}

// ─────────────────────────────────────────────
// CLASS SCHEDULE ENTRY — One cell in the class timetable grid
// ─────────────────────────────────────────────
model ClassScheduleEntry {
  id                Int    @id @default(autoincrement())
  classTimetableId  Int
  periodNumber      Int
  day               String
  courseAllocationId Int
  room              String?
  classType         String @default("class")

  classTimetable   ClassTimetable   @relation(fields: [classTimetableId], references: [id], onDelete: Cascade)
  courseAllocation  CourseAllocation @relation(fields: [courseAllocationId], references: [id], onDelete: Cascade)

  @@unique([classTimetableId, periodNumber, day])
  @@index([courseAllocationId])
}

// ─────────────────────────────────────────────
// COURSE (was Subject) — A subject/paper
// ─────────────────────────────────────────────
model Course {
  id         Int      @id @default(autoincrement())
  name       String
  code       String   @unique // e.g. "BCA-101"
  department String
  semester   Int
  credits    Int      @default(3)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  enrolledStudents StudentCourse[]
  allocations      CourseAllocation[]
  attendanceStats  StudentAttendanceStat[]
}

// ─────────────────────────────────────────────
// STUDENT-COURSE — Join table (replaces student.courses[] array)
// ─────────────────────────────────────────────
model StudentCourse {
  studentId Int
  courseId  Int

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([studentId, courseId]) // Composite primary key — a student can't enroll in same course twice
  @@index([courseId])
}

// ─────────────────────────────────────────────
// COURSE ALLOCATION — "Who teaches what, to whom, and where?"
// ─────────────────────────────────────────────
model CourseAllocation {
  id           Int      @id @default(autoincrement())
  teacherId    Int
  courseId     Int
  department   String
  semester     Int
  section      String
  academicYear String   @default("2025-2026")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  teacher            Teacher             @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  course             Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendanceSessions AttendanceSession[]
  schedules          TeacherSchedule[]
  classScheduleEntries ClassScheduleEntry[]

  @@unique([teacherId, courseId, department, semester, section]) // A teacher can't be assigned same course+section twice
  @@index([courseId])
}

// ─────────────────────────────────────────────
// ATTENDANCE SESSION — One class session (was: Attendance document header)
// ─────────────────────────────────────────────
model AttendanceSession {
  id                 Int      @id @default(autoincrement())
  courseAllocationId Int
  date               DateTime @default(now())
  createdAt          DateTime @default(now())

  // Relations
  courseAllocation CourseAllocation   @relation(fields: [courseAllocationId], references: [id], onDelete: Cascade)
  records          AttendanceRecord[]

  @@unique([courseAllocationId, date]) // Can't take attendance for same class twice on same day
}

// ─────────────────────────────────────────────
// ATTENDANCE RECORD — One student's status in a session (was: records[] array)
// ─────────────────────────────────────────────
model AttendanceRecord {
  id        Int              @id @default(autoincrement())
  sessionId Int
  studentId Int
  status    AttendanceStatus @default(PRESENT)

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId]) // A student can only have one status per session
  @@index([studentId]) // Fast lookup: "find all sessions for a given student"
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

// ─────────────────────────────────────────────
// STUDENT ATTENDANCE STAT — Live cached percentage data
// ─────────────────────────────────────────────
model StudentAttendanceStat {
  id            Int @id @default(autoincrement())
  studentId     Int
  courseId      Int
  totalSessions Int @default(0)
  totalAttended Int @default(0)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([courseId])
}

// ─────────────────────────────────────────────
// LIBRARY RESOURCE — User-contributed Google Drive links
// ─────────────────────────────────────────────
model LibraryResource {
  id            Int      @id @default(autoincrement())
  title         String
  subjectName   String
  department    String
  semester      Int
  driveLink     String   @db.Text
  description   String?  @db.Text
  contributorId Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contributor User @relation(fields: [contributorId], references: [id], onDelete: Cascade)

  @@index([contributorId])
  @@index([department, semester])
}
